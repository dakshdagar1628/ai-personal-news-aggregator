# =============================================================================
# AI INTELLIGENCE OS — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:your_db_password@db.your-project.supabase.co:5432/postgres


# AI — CLAUDE (Primary)
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-opus-4-5
CLAUDE_MAX_TOKENS=4096

# AI — OPENAI (Secondary / Optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# GITHUB
GITHUB_TOKEN=your_github_personal_access_token

# REDDIT
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_client_secret
REDDIT_USER_AGENT=ai-intelligence-os/1.0

# YOUTUBE
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# PRODUCT HUNT
PRODUCT_HUNT_API_TOKEN=your_product_hunt_api_token
PRODUCT_HUNT_API_SECRET=your_product_hunt_api_secret

# APP CONFIG
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Intelligence OS
NODE_ENV=development

# N8N
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret
N8N_BASE_URL=http://localhost:5678

# EMAIL (Future — Phase 8)
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=digest@yourdomain.com

# ── Phase 6: AI Processing Engine ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-latest
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash
AI_PROVIDER=openrouter
PROCESSING_VERSION=1.0.0
