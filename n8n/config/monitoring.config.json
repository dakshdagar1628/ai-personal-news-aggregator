{
  "_comment": "Monitoring architecture. No dashboard yet — data model for Phase 6.",
  "metrics": {
    "per_workflow": [
      "total_executions", "success_count", "failure_count",
      "avg_duration_ms", "last_success_at", "last_failure_at",
      "last_error_message", "items_processed_total", "items_stored_total",
      "items_skipped_total", "retry_count"
    ],
    "per_source": [
      "last_checked_at", "error_count", "consecutive_failures",
      "avg_items_per_run", "total_items_collected"
    ],
    "global": [
      "active_workflows", "total_news_today",
      "total_sources_active", "report_status"
    ]
  },
  "alertThresholds": {
    "consecutiveFailures": 3,
    "maxDurationMs": 120000,
    "minItemsPerRun": 0
  },
  "storage": {
    "strategy": "supabase_table",
    "table": "workflow_logs",
    "retentionDays": 30
  }
}
